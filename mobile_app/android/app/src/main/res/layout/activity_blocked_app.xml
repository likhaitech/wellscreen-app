<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/blockedAppRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/blockedAppTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/blocked_app_title"
        android:textColor="#111827"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blockedAppMessageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="@string/blocked_app_message"
        android:textColor="#4B5563"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/blockedAppNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textColor="#DC2626"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blockedAppPackageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#6B7280"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/blockedAppReasonText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center"
        android:textColor="#111827"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blockedAppCooldownText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#2563EB"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blockedAppAttemptText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#111827"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/blockedAppLeaveButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#2563EB"
        android:text="@string/blocked_app_leave_button"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
