<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/blockedWebsiteRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="28dp">

    <TextView
        android:id="@+id/blockedWebsiteTitleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/blocked_website_title"
        android:textColor="#111827"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blockedWebsiteMessageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="@string/blocked_website_message"
        android:textColor="#4B5563"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/blockedWebsiteDomainText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:textColor="#DC2626"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/blockedWebsiteCategoryText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:textColor="#6B7280"
        android:textSize="14sp" />

    <Button
        android:id="@+id/blockedWebsiteLeaveButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="32dp"
        android:backgroundTint="#2563EB"
        android:text="@string/blocked_website_leave_button"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
